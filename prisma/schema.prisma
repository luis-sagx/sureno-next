generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum OrderType {
  RETAIL
  WHOLESALE
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  role      Role     @default(CUSTOMER)
  type      String   @default("INDIVIDUAL") // INDIVIDUAL or WHOLESALE
  company   String?
  taxId     String?
  address   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  orders     Order[]
  activities UserActivity[]

  @@map("users")
}

model Product {
  id          String    @id @default(uuid())
  slug        String    @unique
  name        String
  description String
  origin      String?
  volumeMl    Int?      @map("volume_ml")
  abv         Decimal?  @db.Decimal(4, 1)
  type        String    // SPIRIT, WINE, BEER, PACK
  imageUrl    String?   @map("image_url")
  badge       String?   // SAVE_15, BEST_SELLER, LIMITED_STOCK, PREMIUM_RESERVE
  retailPrice Decimal   @map("retail_price") @db.Decimal(10, 2)
  categoryId  String    @map("category_id")
  brandId     String?   @map("brand_id")
  aroma       String?
  palate      String?
  finish      String?
  stockStatus String    @default("HIGH") @map("stock_status") // HIGH, MEDIUM, LOW, OUT
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  category Category @relation(fields: [categoryId], references: [id])
  brand    Brand?   @relation(fields: [brandId], references: [id])
  variants Variant[]

  @@map("products")
}

model Variant {
  id        String  @id @default(uuid())
  productId String  @map("product_id")
  label     String  // e.g. "750ml", "Caja 12 unids"
  price     Decimal @db.Decimal(10, 2)
  stock     Int     @default(0)
  minOrder  Int     @default(1) @map("min_order")

  product        Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  wholesaleTiers WholesaleTier[]
  orderItems     OrderItem[]

  @@map("variants")
}

model WholesaleTier {
  id           String  @id @default(uuid())
  variantId    String  @map("variant_id")
  minQty       Int     @map("min_qty")
  maxQty       Int?    @map("max_qty")
  pricePerUnit Decimal @map("price_per_unit") @db.Decimal(10, 2)
  label        String? // e.g. "1-5 unids", "6-11 unids", "12+ (Caja)"

  variant Variant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@map("wholesale_tiers")
}

model Category {
  id       String    @id @default(uuid())
  name     String
  slug     String    @unique
  icon     String    // Material icon name
  products Product[]

  @@map("categories")
}

model Brand {
  id       String    @id @default(uuid())
  name     String
  slug     String    @unique
  imageUrl String?   @map("image_url")
  products Product[]

  @@map("brands")
}

model CartItem {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  variantId String   @map("variant_id")
  quantity  Int      @default(1)
  type      String   @default("RETAIL") // RETAIL or WHOLESALE
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("cart_items")
}

model Order {
  id                String      @id @default(uuid())
  orderNumber       String      @unique @map("order_number")
  userId            String?     @map("user_id")
  fullName          String      @map("full_name")
  company           String?
  street            String
  city              String
  zipCode           String      @map("zip_code")
  paymentMethod     String      @map("payment_method") // DIRECT_PAYMENT or WHOLESALE_QUOTE
  retailSubtotal    Decimal     @map("retail_subtotal") @db.Decimal(10, 2)
  wholesaleSubtotal Decimal?    @map("wholesale_subtotal") @db.Decimal(10, 2)
  shippingCost      Decimal     @default(0) @map("shipping_cost") @db.Decimal(10, 2)
  total             Decimal     @db.Decimal(10, 2)
  status            OrderStatus @default(PENDING)
  type              OrderType   @default(RETAIL)
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id])
  items OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String  @map("order_id")
  variantId String  @map("variant_id")
  quantity  Int
  unitPrice Decimal @map("unit_price") @db.Decimal(10, 2)
  type      String  @default("RETAIL") // RETAIL or WHOLESALE

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant Variant @relation(fields: [variantId], references: [id])

  @@map("order_items")
}

model UserActivity {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  action    String
  details   String?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_activities")
}
